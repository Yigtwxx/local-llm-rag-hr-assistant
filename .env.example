# Copy to .env and adjust. Never commit the real .env file.

# --- Ollama runtime ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=120

# --- Models ---
# Two mid-size chat models are benchmarked against each other.
CHAT_MODEL_PRIMARY=qwen3.5:9b
CHAT_MODEL_SECONDARY=gemma4:12b
EMBEDDING_MODEL=qwen3-embedding:0.6b

# --- Retrieval ---
KB_DIR=../data/kb
STORAGE_DIR=./storage
COLLECTION_NAME=hr_kb
CHUNK_SIZE=500
CHUNK_OVERLAP=75
TOP_K=4
# Cosine similarity floor. Below this the assistant refuses instead of guessing.
# Measured, not guessed — rerun `bench/calibrate_threshold.py` after changing
# the knowledge base. See app/config.py for why this value and not a higher one.
SIMILARITY_THRESHOLD=0.46

# --- Generation ---
TEMPERATURE=0.0
SEED=42
MAX_TOKENS=1024

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- Docker (read by `docker compose` only) ---
# scripts/dev.sh ignores these. Chosen to stay clear of 8000/5173 above, so the
# containers and a local dev server can run side by side.
WEB_PORT=8180
BACKEND_HOST_PORT=8100
# Ollama is not containerised; the backend reaches the host's instance. The
# DOCKER_ prefix keeps OLLAMA_HOST above — which points at localhost, wrong
# from inside a container — from being interpolated into compose.
DOCKER_OLLAMA_HOST=http://host.docker.internal:11434
